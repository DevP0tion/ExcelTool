{
  "name": "xlmcp",
  "version": "0.3.0",
  "description": "Excel automation MCP server via PowerShell COM. 48 tools — session pooling, chunked parallel I/O, virtual clipboard. Windows only.",
  "license": "MIT",
  "author": "DevP0tion",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevP0tion/XLMCP"
  },
  "homepage": "https://github.com/DevP0tion/XLMCP",
  "keywords": [
    "mcp",
    "excel",
    "powershell",
    "com",
    "automation",
    "spreadsheet",
    "claude",
    "model-context-protocol"
  ],
  "os": ["win32"],
  "type": "module",
  "bin": {
    "xlmcp": "dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "node-powershell": "^5.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bun": "^1.2.14",
    "typescript": "^5.8.3"
  }
}
